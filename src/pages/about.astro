---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Button from '../components/ui/Button.astro';
import Badge from '../components/ui/Badge.astro';
import CTA from '../components/sections/CTA.astro';
import { siteConfig } from '../config/siteConfig';

const coachName = siteConfig.coach.name;
const coachTitle = siteConfig.coach.title;
const certifications = siteConfig.certifications;
---

<BaseLayout
  title={`About ${coachName} | ${coachTitle}`}
  description={`${coachName} is a ${coachTitle} specializing in mold toxicity, Endometriosis, chronic illness, and emotional healing. Learn about her certifications and approach.`}
  page="about"
>
  <Header slot="header" />

  <!-- Hero Section -->
  <section class="relative py-14 md:py-24 bg-gradient-to-br from-secondary-50 via-white to-primary-50 overflow-hidden">
    <!-- Decorative elements -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary-100 rounded-full opacity-30 blur-3xl translate-x-1/2 -translate-y-1/2"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-accent-100 rounded-full opacity-30 blur-3xl -translate-x-1/2 translate-y-1/2"></div>

    <div class="container mx-auto px-4 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Image Column -->
        <div class="flex justify-center lg:justify-start order-2 lg:order-1" data-aos="fade-right">
          <div class="relative mx-8 sm:mx-12 lg:mx-0">
            <!-- Decorative background shapes -->
            <div class="absolute -top-5 -left-5 w-full h-full rounded-2xl transform -rotate-3" style="background-color: rgba(152,216,170,0.35);"></div>
            <div class="absolute -bottom-5 -right-5 w-full h-full rounded-2xl transform rotate-3" style="background-color: rgba(13,148,136,0.2);"></div>

            <!-- Wellness imagery -->
            <img
              src={siteConfig.images.portrait}
              alt="Natural herbs and wellness remedies representing functional medicine and root-cause healing"
              width="1024" height="1024"
              decoding="async"
              class="relative w-56 sm:w-72 md:w-80 lg:w-96 rounded-2xl shadow-2xl ring-4 ring-white"
              style="display: block; width: 100%; height: auto; object-fit: cover; aspect-ratio: 4/5;"
              loading="eager"
            />

            <!-- Floating credential badge -->
            <div class="absolute -bottom-4 -right-4 rounded-xl px-4 py-3 shadow-lg text-center" style="background-color: #1B3A5C;">
              <p class="font-heading font-bold text-2xl leading-none" style="color: #0D9488;">8</p>
              <p class="font-body text-xs mt-0.5" style="color: #98D8AA;">Certifications</p>
            </div>
          </div>
        </div>

        <!-- Content Column -->
        <div class="order-1 lg:order-2" data-aos="fade-left" data-aos-delay="100">
          <span class="inline-block text-primary-600 font-medium text-sm uppercase tracking-wider mb-3">
            About Me
          </span>

          <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-heading font-bold text-primary-900 leading-tight">
            Hi, I'm {coachName.split(' ')[0]}
          </h1>

          <p class="mt-2 text-xl md:text-2xl text-primary-600 font-heading font-medium">
            {coachTitle}
          </p>

          <!-- Pullquote -->
          <blockquote class="mt-6 pl-6" style="border-left: 3px solid #0D9488;">
            <p class="text-xl font-heading italic leading-relaxed" style="color: #1B3A5C;">
              "{siteConfig.bio.pullquote}"
            </p>
            <cite class="mt-2 block text-sm font-body text-gray-500 not-italic">— {coachName}</cite>
          </blockquote>

          <!-- Quick stats -->
          <div class="mt-8 flex flex-wrap gap-6">
            <div class="text-center">
              <p class="text-3xl md:text-4xl font-heading font-bold text-primary-600">8</p>
              <p class="text-sm text-gray-600 font-body">Certifications</p>
            </div>
            <div class="text-center">
              <p class="text-3xl md:text-4xl font-heading font-bold text-primary-600">3</p>
              <p class="text-sm text-gray-600 font-body">Service Options</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Certifications Section -->
  <section class="py-14 md:py-24 bg-white" data-aos="fade-up">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="inline-block text-primary-600 font-medium text-sm uppercase tracking-wider mb-3">
          Credentials
        </span>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary-900">
          My Certifications
        </h2>
        <p class="mt-4 text-lg text-gray-700 font-body">
          I bring a unique combination of functional medicine expertise and holistic healing skills to help you on your path to wellness.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {certifications.map((cert, index) => (
          <div
            class="bg-white rounded-xl p-6 shadow-md hover:shadow-lg transition-shadow duration-300 text-center"
            data-aos="fade-up"
            data-aos-delay={index * 100}
          >
            <div class="mb-4">
              <Badge variant={cert.variant} class="text-base px-4 py-2">
                {cert.title.includes('(') ? cert.title.match(/\(([^)]+)\)/)?.[1] : cert.title.split(' ').map(w => w[0]).join('')}
              </Badge>
            </div>
            <h3 class="text-lg font-heading font-semibold text-primary-900 mb-2">
              {cert.title}
            </h3>
            <p class="text-sm text-gray-600 font-body">
              {cert.description}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTA />

  <Footer slot="footer" />
</BaseLayout>
