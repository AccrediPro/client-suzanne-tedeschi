---
import { siteConfig } from '../config/siteConfig';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import AboutPreview from '../components/sections/AboutPreview.astro';
import ServicesPreview from '../components/sections/ServicesPreview.astro';
import WhoIWorkWith from '../components/sections/WhoIWorkWith.astro';
import CTA from '../components/sections/CTA.astro';
---

<BaseLayout
  title={`${siteConfig.coach.name} — ${siteConfig.coach.title}`}
  description={siteConfig.site.description}
>
  <Header slot="header" />

  <!-- 1. Hero — split layout with real image -->
  <Hero />

  <!-- 2. About Preview — with coach portrait -->
  <AboutPreview />

  <!-- 3. Services Preview — Most Popular highlighted -->
  <ServicesPreview />

  <!-- 4. Who I Work With -->
  <WhoIWorkWith />

  <!-- 5. CTA — with success background image -->
  <CTA />

  <Footer slot="footer" />
</BaseLayout>
