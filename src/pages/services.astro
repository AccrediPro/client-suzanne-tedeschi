---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import CTA from '../components/sections/CTA.astro';
import { siteConfig } from '../config/siteConfig';

const services = siteConfig.servicesDetail;

---

<BaseLayout
  title={`Services | ${siteConfig.coach.name} - ${siteConfig.coach.title}`}
  description={`${siteConfig.coach.name} offers personalized functional medicine coaching: free discovery calls, 60-minute and 30-40 minute consultations with custom healing plans.`}
  page="services"
>
  <Header slot="header" />

  <!-- Hero Section -->
  <section class="relative py-14 md:py-24 bg-gradient-to-br from-secondary-50 via-white to-primary-50 overflow-hidden">
    <!-- Decorative elements -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary-100 rounded-full opacity-30 blur-3xl translate-x-1/2 -translate-y-1/2"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-accent-100 rounded-full opacity-30 blur-3xl -translate-x-1/2 translate-y-1/2"></div>

    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-3xl mx-auto text-center" data-aos="fade-up">
        <span class="inline-block text-primary-600 font-medium text-sm uppercase tracking-wider mb-3">
          Functional Medicine Coaching
        </span>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold leading-tight" style="color: #1B3A5C; letter-spacing: -0.02em; line-height: 1.1;">
          Programs to <span class="text-primary-600">Restore</span> Your Health
        </h1>
        <p class="mt-6 text-lg md:text-xl font-body" style="color: #3a3a3a; line-height: 1.7;">
          Personalized health coaching designed to uncover the root cause of your concerns and guide you toward lasting wellness.
        </p>
      </div>
    </div>
  </section>

  <!-- Services Visual Banner -->
  <div class="relative overflow-hidden">
    <img
      src="/images/unsplash/wellness-1.jpg"
      alt="Wellness coaching — personalized health and functional medicine coaching"
      width="1080"
      height="608"
      class="w-full"
      style="display: block; height: auto;"
      loading="lazy"
    />
    <div class="absolute inset-0" style="background: linear-gradient(to bottom, transparent 50%, rgba(255,255,255,1) 100%);"></div>
  </div>

  <!-- Services Detail Section -->
  <section class="pt-6 pb-14 md:pb-24 bg-white">
    <div class="container mx-auto px-4">
      {services.map((service, index) => (
        <div
          id={service.id}
          class={`py-12 ${index !== 0 ? 'border-t border-gray-100' : ''}`}
          data-aos="fade-up"
        >
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start max-w-6xl mx-auto">
            <!-- Content Side -->
            <div class={index % 2 === 1 ? 'lg:order-2' : ''}>
              <div class="text-primary-500 mb-4">
                <Fragment set:html={service.icon} />
              </div>
              <div class="flex items-center gap-3 mb-2">
                <h2 class="text-2xl md:text-3xl font-heading font-bold" style="color: #1B3A5C;">
                  {service.title}
                </h2>
                <span class={`inline-block rounded-full px-3 py-1 text-sm font-bold ${service.price === 'FREE' ? 'bg-accent-100 text-accent-800' : 'bg-primary-100 text-primary-800'}`}>
                  {service.price}
                </span>
              </div>
              <p class="font-medium mb-1" style="color: #1B3A5C;">
                {service.subtitle}
              </p>
              <p class="text-sm text-gray-600 font-body mb-4">
                {service.duration}
              </p>
              <p class="text-lg font-body mb-6" style="color: #3a3a3a; line-height: 1.7;">
                {service.description}
              </p>

              <div class="bg-accent-50 rounded-lg p-4 mb-6">
                <p class="text-sm font-medium text-accent-700">
                  <span class="font-semibold">Ideal for:</span> {service.idealFor}
                </p>
              </div>

              <Button href="/contact" variant="primary">
                {service.price === 'FREE' ? 'Book Your Free Discovery Call' : 'Get Started'}
              </Button>
            </div>

            <!-- Features Side -->
            <div class={index % 2 === 1 ? 'lg:order-1' : ''}>
              <Card class="h-full">
                <h3 class="text-lg font-heading font-semibold text-primary-900 mb-4">
                  What's Included
                </h3>
                <ul class="space-y-3">
                  {service.features.map((feature) => (
                    <li class="flex items-start gap-3">
                      <svg class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                      </svg>
                      <span class="font-body" style="color: #3a3a3a;">{feature}</span>
                    </li>
                  ))}
                </ul>
              </Card>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Pricing Comparison Section -->
  <section class="py-14 md:py-24 bg-secondary-50" data-aos="fade-up">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="inline-block text-primary-600 font-medium text-sm uppercase tracking-wider mb-3">
          Investment in Your Health
        </span>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary-900">
          Transparent Pricing
        </h2>
        <p class="mt-4 text-lg text-gray-700 font-body">
          Choose the option that fits your needs. Every journey begins with a free discovery call.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 md:gap-8 max-w-5xl mx-auto">
        <!-- Free Discovery Call -->
        <Card class="text-center relative">
          <div class="mb-4">
            <span class="inline-block bg-accent-100 text-accent-800 text-xs font-bold uppercase tracking-wider rounded-full px-3 py-1">
              Start Here
            </span>
          </div>
          <h3 class="text-xl font-heading font-semibold text-primary-900 mb-2">
            Free Discovery Call
          </h3>
          <div class="text-4xl font-heading font-bold text-primary-600 mb-1">
            FREE
          </div>
          <p class="text-sm text-gray-600 mb-6">15 minutes</p>
          <ul class="text-left space-y-2 mb-6">
            <li class="flex items-center gap-2 text-gray-700 font-body text-sm">
              <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Discuss your health concerns
            </li>
            <li class="flex items-center gap-2 text-gray-700 font-body text-sm">
              <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Learn about Suzanne's approach
            </li>
            <li class="flex items-center gap-2 text-gray-700 font-body text-sm">
              <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              No pressure, no obligation
            </li>
          </ul>
          <Button href="/contact" variant="secondary" class="w-full">
            Book Your Free Discovery Call
          </Button>
        </Card>

        <!-- 60-Minute Consultation -->
        <Card class="text-center relative ring-2 ring-primary-500 shadow-lg">
          <div class="mb-4">
            <span class="inline-block bg-primary-600 text-white text-xs font-bold uppercase tracking-wider rounded-full px-3 py-1">
              Most Popular
            </span>
          </div>
          <h3 class="text-xl font-heading font-semibold text-primary-900 mb-2">
            Initial Consultation
          </h3>
          <div class="text-4xl font-heading font-bold text-primary-600 mb-1">
            $250
          </div>
          <p class="text-sm text-gray-600 mb-6">60-minute session</p>
          <ul class="text-left space-y-2 mb-6">
            <li class="flex items-center gap-2 text-gray-700 font-body text-sm">
              <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Full health history review
            </li>
            <li class="flex items-center gap-2 text-gray-700 font-body text-sm">
              <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Personalized healing guide
            </li>
            <li class="flex items-center gap-2 text-gray-700 font-body text-sm">
              <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Custom nutrition plan
            </li>
            <li class="flex items-center gap-2 text-gray-700 font-body text-sm">
              <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Lifestyle modification recommendations
            </li>
          </ul>
          <Button href="/contact" variant="primary" class="w-full">
            Get Started
          </Button>
        </Card>

        <!-- 30-40 Minute Consultation -->
        <Card class="text-center relative">
          <div class="mb-4">
            <span class="inline-block bg-primary-100 text-primary-800 text-xs font-bold uppercase tracking-wider rounded-full px-3 py-1">
              Focused
            </span>
          </div>
          <h3 class="text-xl font-heading font-semibold text-primary-900 mb-2">
            Initial Consultation
          </h3>
          <div class="text-4xl font-heading font-bold text-primary-600 mb-1">
            $150
          </div>
          <p class="text-sm text-gray-600 mb-6">30–40 minute session</p>
          <ul class="text-left space-y-2 mb-6">
            <li class="flex items-center gap-2 text-gray-700 font-body text-sm">
              <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Focused health concern review
            </li>
            <li class="flex items-center gap-2 text-gray-700 font-body text-sm">
              <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Personalized healing guide
            </li>
            <li class="flex items-center gap-2 text-gray-700 font-body text-sm">
              <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Custom nutrition plan
            </li>
            <li class="flex items-center gap-2 text-gray-700 font-body text-sm">
              <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              Lifestyle modification recommendations
            </li>
          </ul>
          <Button href="/contact" variant="secondary" class="w-full">
            Get Started
          </Button>
        </Card>
      </div>
    </div>
  </section>

  <!-- Comparison Table Section -->
  <section class="py-16 md:py-20 bg-white" data-aos="fade-up">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-10">
          <span class="inline-block text-primary-600 font-medium text-sm uppercase tracking-wider mb-3">
            Side by Side
          </span>
          <h2 class="text-2xl md:text-3xl font-heading font-bold" style="color: #1B3A5C;">
            Compare Your Options
          </h2>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-left border-collapse font-body">
            <thead>
              <tr class="border-b-2 border-primary-200">
                <th class="py-3 px-4 text-sm font-heading font-semibold text-gray-700">Feature</th>
                <th class="py-3 px-4 text-sm font-heading font-semibold text-gray-700">Free Discovery</th>
                <th class="py-3 px-4 text-sm font-heading font-semibold text-white rounded-t-lg" style="background-color: #1B3A5C;">60-Min Consultation</th>
                <th class="py-3 px-4 text-sm font-heading font-semibold text-gray-700">30–40 Min Consultation</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-gray-100">
                <td class="py-3 px-4 font-medium text-sm text-gray-700">Duration</td>
                <td class="py-3 px-4 text-sm text-gray-600">15 minutes</td>
                <td class="py-3 px-4 text-sm text-gray-700" style="background-color: rgba(27,58,92,0.08);">60 minutes</td>
                <td class="py-3 px-4 text-sm text-gray-600">30–40 minutes</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-3 px-4 font-medium text-sm text-gray-700">Price</td>
                <td class="py-3 px-4 text-sm text-gray-600">Free</td>
                <td class="py-3 px-4 text-sm font-semibold" style="background-color: rgba(27,58,92,0.08); color: #1B3A5C;">$250</td>
                <td class="py-3 px-4 text-sm text-gray-600">$150</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-3 px-4 font-medium text-sm text-gray-700">Healing Guide</td>
                <td class="py-3 px-4 text-sm text-gray-400">—</td>
                <td class="py-3 px-4 text-sm text-primary-600 font-medium" style="background-color: rgba(27,58,92,0.08);">&#10003; Included</td>
                <td class="py-3 px-4 text-sm text-primary-600 font-medium">&#10003; Included</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-3 px-4 font-medium text-sm text-gray-700">Nutrition Plan</td>
                <td class="py-3 px-4 text-sm text-gray-400">—</td>
                <td class="py-3 px-4 text-sm text-primary-600 font-medium" style="background-color: rgba(27,58,92,0.08);">&#10003; Included</td>
                <td class="py-3 px-4 text-sm text-primary-600 font-medium">&#10003; Included</td>
              </tr>
              <tr class="border-b border-gray-100">
                <td class="py-3 px-4 font-medium text-sm text-gray-700">Lifestyle Modifications</td>
                <td class="py-3 px-4 text-sm text-gray-400">—</td>
                <td class="py-3 px-4 text-sm text-primary-600 font-medium" style="background-color: rgba(27,58,92,0.08);">&#10003; Included</td>
                <td class="py-3 px-4 text-sm text-primary-600 font-medium">&#10003; Included</td>
              </tr>
              <tr>
                <td class="py-3 px-4 font-medium text-sm text-gray-700">Best For</td>
                <td class="py-3 px-4 text-sm text-gray-600">Getting started</td>
                <td class="py-3 px-4 text-sm text-gray-600" style="background-color: rgba(27,58,92,0.08);">Comprehensive assessment</td>
                <td class="py-3 px-4 text-sm text-gray-600">Focused health concern</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="py-14 md:py-24 bg-white" data-aos="fade-up">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <span class="inline-block text-primary-600 font-medium text-sm uppercase tracking-wider mb-3">
          Questions?
        </span>
        <h2 class="text-3xl md:text-4xl font-heading font-bold text-primary-900 mb-6">
          Ready to Get Started?
        </h2>
        <p class="text-lg text-gray-700 font-body mb-8">
          Your first discovery call is always free — no obligation, no pressure. Reach out and let's talk about your health concerns.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button href="/contact" variant="primary" size="lg">
            Book Your Free Discovery Call
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <CTA />

  <Footer slot="footer" />
</BaseLayout>
